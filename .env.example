# Email delivery for the contact form (Resend — https://resend.com)
# 1. Create a free Resend account and verify the sending domain (or use the test domain).
# 2. Create an API key and paste it below.
# REQUIRED in production — without it the contact form returns an error (it will
# NOT show a false success), so leads are never silently lost.
RESEND_API_KEY=

# Address that receives lead notifications from the contact form.
LEAD_TO_EMAIL=cesaredgarmejia0603@gmail.com

# Address CC'd on every lead notification.
LEAD_CC_EMAIL=hreyesislas@gmail.com

# Verified "from" address. While testing you can use Resend's onboarding@resend.dev,
# but for production deliverability use a verified domain (e.g. leads@cesarrestaurantappliancerepair.com).
LEAD_FROM_EMAIL=onboarding@resend.dev

# Public site URL (used for canonical URLs, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL=https://cesarrestaurantappliancerepair.com
